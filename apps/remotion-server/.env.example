# Server Configuration
PORT=3001

# Public URL for accessing rendered videos
# In production, set this to your domain (e.g., https://yourdomain.com)
PUBLIC_URL=http://localhost:3001

# Remotion Configuration
# Optional: If you have a pre-bundled Remotion project, set this URL
# Otherwise, the server will bundle the compositions on startup
REMOTION_SERVE_URL=

# Renders directory (where output videos are stored)
RENDERS_DIR=./renders

# --- Performance Tuning ---

# Maximum number of render jobs that run in parallel.
# Higher values increase throughput but consume more CPU/RAM.
# Recommended: 1 on single-core machines, 2–4 on multi-core servers.
# Default: 1
MAX_CONCURRENT_RENDERS=1

# Number of CPU threads (Chromium tabs) used per render job.
# Leave unset to let Remotion auto-detect based on available CPUs.
# Set to a lower value (e.g. 2) to limit memory usage per job.
# RENDER_CONCURRENCY=

# Per-render timeout in milliseconds.
# Jobs that exceed this limit are automatically marked as failed.
# Default: 300000 (5 minutes)
RENDER_TIMEOUT_MS=300000
