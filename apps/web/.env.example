# OpenAI API Key for AI features
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Python Processing Engine URL (client-side, prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_PYTHON_ENGINE_URL=http://localhost:8000

# Remotion Render Server URL (server-side)
REMOTION_SERVER_URL=http://localhost:3001

# Python Engine URL for Docker container-to-container communication
PYTHON_ENGINE_INTERNAL_URL=http://processing-engine:8000

# PostgreSQL Database URL
# Matches credentials from root .env.docker
DATABASE_URL=postgresql://videowizard:videowizard@localhost:5432/videowizard
