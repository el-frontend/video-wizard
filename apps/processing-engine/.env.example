# OpenAI API Configuration
# Sign up at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# Transcription Method
# Set to "true" to use OpenAI API (recommended for Spanish videos)
# Set to "false" to use local Whisper model (requires GPU for good performance)
USE_OPENAI_API=true

# Local Whisper Model (only used if USE_OPENAI_API=false)
# Options: tiny, base, small, medium, large
# Note: large model is ~3GB and requires significant compute resources
WHISPER_MODEL=base
