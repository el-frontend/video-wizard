# PostgreSQL Configuration
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=your_db_name

# Connection URL for the web app (running on host via pnpm dev)
# Uses localhost because the web app runs outside Docker
DATABASE_URL=postgresql://your_db_user:your_secure_password@localhost:5432/your_db_name

# For services running inside Docker containers, use the service name instead:
# DATABASE_URL=postgresql://your_db_user:your_secure_password@postgres:5432/your_db_name
